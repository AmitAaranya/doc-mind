# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=doc-mind
APP_VERSION=0.1.0
ENV=development          # development | staging | production
DEBUG=true

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=false           # true in production for structured / JSON logs

# ── GOOGLE LLM CONFIG ─────────────────────────────────────────────
GOOGLE_CLOUD_API_KEY=
GOOGLE_GENAI_MODEL=gemini-3.1-flash-lite-preview
