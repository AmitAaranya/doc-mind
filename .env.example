# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=doc-mind
APP_VERSION=0.1.0
ENV=development          # development | staging | production
DEBUG=true

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=false           # true in production for structured / JSON logs

# ── Optional Infra (generic) ─────────────────────────────────────────────────
DATABASE_URL=
VECTOR_DB_URL=
STORAGE_BUCKET=
LLM_API_KEY=
